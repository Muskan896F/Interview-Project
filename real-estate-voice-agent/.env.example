# ──────────────────────────────────────────────
# Real Estate Voice Agent — Environment Config Template
# ──────────────────────────────────────────────

# LLM Provider: "openai"
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Deepgram STT (Speech-to-Text) API Key
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Sarvam Bulbul TTS (Text-to-Speech) API Key
SARVAM_API_KEY=your_sarvam_api_key_here

# Database Settings
DATABASE_URL=sqlite:///./data/leads.db

# Server Config
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
